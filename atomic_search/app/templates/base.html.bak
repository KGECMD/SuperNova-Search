<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Atomic Search - Privacy-first search engine with AI capabilities">
    <meta name="robots" content="noindex, nofollow">
    <title>{% block title %}{{ config.APP_NAME }} - Privacy-First Search{% endblock %}</title>
    
    <!-- Preload critical resources -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🔬</text></svg>">
    
    <style>
        :root {
            --bg-primary: #0a0a1a;
            --bg-secondary: #12122a;
            --bg-card: rgba(30, 30, 60, 0.8);
            --bg-glass: rgba(255, 255, 255, 0.05);
            --text-primary: #ffffff;
            --text-secondary: #a0a0c0;
            --text-muted: #606080;
            --accent: #667eea;
            --accent-hover: #764ba2;
            --success: #10b981;
            --error: #ef4444;
            --border: rgba(255, 255, 255, 0.1);
            --shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            --radius: 16px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        [data-theme="light"] {
            --bg-primary: #f8fafc;
            --bg-secondary: #f1f5f9;
            --bg-card: rgba(255, 255, 255, 0.9);
            --bg-glass: rgba(255, 255, 255, 0.7);
            --text-primary: #1e293b;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
            --border: rgba(0, 0, 0, 0.1);
            --shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Color Emoji', 'Apple Color Emoji', 'Segoe UI Emoji', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.6;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Animated background */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: 
                radial-gradient(ellipse at 20% 20%, rgba(102, 126, 234, 0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 80%, rgba(118, 75, 162, 0.15) 0%, transparent 50%);
            pointer-events: none;
            z-index: -1;
        }

        /* Header */
        .header {
            background: var(--bg-glass);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            padding: 15px 0;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .header-content {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            color: var(--text-primary);
            font-weight: 700;
            font-size: 1.4em;
        }

        .logo-icon {
            font-size: 1.8em;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        /* Search form */
        .search-container {
            flex: 1;
            max-width: 700px;
        }

        .search-form {
            display: flex;
            align-items: center;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 50px;
            padding: 5px;
            transition: var(--transition);
        }

        .search-form:focus-within {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.2);
        }

        .search-input {
            flex: 1;
            background: transparent;
            border: none;
            padding: 12px 20px;
            font-size: 1em;
            color: var(--text-primary);
            outline: none;
        }

        .search-input::placeholder {
            color: var(--text-muted);
        }

        .search-btn {
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
            border: none;
            border-radius: 50%;
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition);
        }

        .search-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);
        }

        .search-btn svg {
            width: 20px;
            height: 20px;
            fill: white;
        }

        /* Navigation */
        .nav {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .nav-link {
            color: var(--text-secondary);
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 8px;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .nav-link:hover {
            color: var(--text-primary);
            background: var(--bg-glass);
        }

        .nav-link svg {
            width: 18px;
            height: 18px;
        }

        /* Theme toggle */
        .theme-toggle {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition);
        }

        .theme-toggle:hover {
            background: var(--bg-glass);
            transform: rotate(15deg);
        }

        .theme-toggle svg {
            width: 20px;
            height: 20px;
            fill: var(--text-secondary);
        }

        /* Container */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* Glass card */
        .glass-card {
            background: var(--bg-glass);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 30px;
            transition: var(--transition);
        }

        .glass-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow);
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 40px 20px;
            color: var(--text-muted);
            border-top: 1px solid var(--border);
            margin-top: 60px;
        }

        .footer-links {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 15px;
        }

        .footer-links a {
            color: var(--text-secondary);
            text-decoration: none;
            transition: var(--transition);
        }

        .footer-links a:hover {
            color: var(--accent);
        }

        /* Utilities */
        .text-center { text-align: center; }
        .text-gradient {
            background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* SVG Icon styles */
        .icon {
            width: 1.2em;
            height: 1.2em;
            vertical-align: middle;
            fill: currentColor;
        }
        .icon-lg {
            width: 2.5em;
            height: 2.5em;
        }

        /* Theme Selector */
        .theme-selector {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            padding: 15px;
            justify-content: center;
        }
        .theme-btn {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            border: 2px solid transparent;
            cursor: pointer;
            transition: all 0.2s;
        }
        .theme-btn:hover {
            transform: scale(1.2);
            border-color: white;
        }
        .theme-btn.active {
            border-color: white;
            box-shadow: 0 0 8px rgba(255,255,255,0.5);
        }

        /* 50 Themes */
        [data-theme="dark"] { --bg-primary: #0a0a1a; --bg-secondary: #12122a; --bg-card: rgba(30,30,60,0.8); --bg-glass: rgba(255,255,255,0.05); --text-primary: #ffffff; --text-secondary: #a0a0c0; --text-muted: #606080; --accent: #667eea; --accent-hover: #764ba2; --border: rgba(255,255,255,0.1); }
        [data-theme="light"] { --bg-primary: #f8fafc; --bg-secondary: #f1f5f9; --bg-card: rgba(255,255,255,0.9); --bg-glass: rgba(255,255,255,0.7); --text-primary: #1e293b; --text-secondary: #475569; --text-muted: #94a3b8; --accent: #667eea; --accent-hover: #764ba2; --border: rgba(0,0,0,0.1); }
        [data-theme="midnight"] { --bg-primary: #000000; --bg-secondary: #0d0d0d; --bg-card: rgba(20,20,20,0.9); --bg-glass: rgba(40,40,40,0.5); --text-primary: #ffffff; --text-secondary: #b0b0b0; --text-muted: #707070; --accent: #00d4ff; --accent-hover: #0099cc; --border: rgba(255,255,255,0.1); }
        [data-theme="ocean"] { --bg-primary: #0a1628; --bg-secondary: #0f2847; --bg-card: rgba(15,40,71,0.8); --bg-glass: rgba(0,119,182,0.2); --text-primary: #ffffff; --text-secondary: #a8c8e8; --text-muted: #5a8ab8; --accent: #00b4d8; --accent-hover: #0077b6; --border: rgba(0,180,216,0.2); }
        [data-theme="forest"] { --bg-primary: #0d1f0d; --bg-secondary: #1a3a1a; --bg-card: rgba(26,58,26,0.8); --bg-glass: rgba(34,139,34,0.2); --text-primary: #e8f5e8; --text-secondary: #a8d8a8; --text-muted: #5a8a5a; --accent: #228b22; --accent-hover: #32cd32; --border: rgba(34,139,34,0.3); }
        [data-theme="sunset"] { --bg-primary: #1a0a0a; --bg-secondary: #2d1515; --bg-card: rgba(45,21,21,0.8); --bg-glass: rgba(255,69,0,0.15); --text-primary: #fff5f0; --text-secondary: #ffccbb; --text-muted: #cc9988; --accent: #ff6347; --accent-hover: #ff4500; --border: rgba(255,99,71,0.2); }
        [data-theme="purple"] { --bg-primary: #1a0a2e; --bg-secondary: #2d1547; --bg-card: rgba(45,21,71,0.8); --bg-glass: rgba(138,43,226,0.2); --text-primary: #f0e6ff; --text-secondary: #c8a8e8; --text-muted: #8878a8; --accent: #9b59b6; --accent-hover: #8e44ad; --border: rgba(155,89,182,0.3); }
        [data-theme="mint"] { --bg-primary: #f0fff0; --bg-secondary: #e0ffe0; --bg-card: rgba(200,255,200,0.9); --bg-glass: rgba(0,255,127,0.1); --text-primary: #1a3a1a; --text-secondary: #2d5a2d; --text-muted: #5a8a5a; --accent: #00ff7f; --accent-hover: #00cc66; --border: rgba(0,255,127,0.2); }
        [data-theme="rose"] { --bg-primary: #1a0a10; --bg-secondary: #2d1520; --bg-card: rgba(71,21,37,0.8); --bg-glass: rgba(255,0,64,0.15); --text-primary: #fff0f5; --text-secondary: #ffccd5; --text-muted: #cc99aa; --accent: #ff1493; --accent-hover: #ff69b4; --border: rgba(255,20,147,0.2); }
        [data-theme="gold"] { --bg-primary: #1a1500; --bg-secondary: #2d2500; --bg-card: rgba(45,37,0,0.8); --bg-glass: rgba(255,215,0,0.15); --text-primary: #fff8dc; --text-secondary: #ffe4a0; --text-muted: #ccb870; --accent: #ffd700; --accent-hover: #ffb700; --border: rgba(255,215,0,0.3); }
        [data-theme="coral"] { --bg-primary: #fff5f0; --bg-secondary: #ffe0d0; --bg-card: rgba(255,160,122,0.4); --bg-glass: rgba(255,127,80,0.2); --text-primary: #4a2020; --text-secondary: #7a4040; --text-muted: #aa7070; --accent: #ff7f50; --accent-hover: #ff6347; --border: rgba(255,127,80,0.3); }
        [data-theme="slate"] { --bg-primary: #1a1a2e; --bg-secondary: #2d2d47; --bg-card: rgba(45,45,71,0.8); --bg-glass: rgba(106,90,205,0.2); --text-primary: #e6e6fa; --text-secondary: #b8b8d0; --text-muted: #7878a0; --accent: #6a5acd; --accent-hover: #836ffe; --border: rgba(106,90,205,0.3); }
        [data-theme="teal"] { --bg-primary: #001a1a; --bg-secondary: #003333; --bg-card: rgba(0,51,51,0.8); --bg-glass: rgba(0,128,128,0.2); --text-primary: #e0ffff; --text-secondary: #a0d8d8; --text-muted: #60a0a0; --accent: #008080; --accent-hover: #00a0a0; --border: rgba(0,128,128,0.3); }
        [data-theme="lavender"] { --bg-primary: #faf0ff; --bg-secondary: #f0d0ff; --bg-card: rgba(230,180,255,0.4); --bg-glass: rgba(181,126,220,0.2); --text-primary: #3a1a4a; --text-secondary: #5a2a6a; --text-muted: #8a5a9a; --accent: #b57edc; --accent-hover: #9966cc; --border: rgba(181,126,220,0.3); }
        [data-theme="crimson"] { --bg-primary: #1a0505; --bg-secondary: #2d0a0a; --bg-card: rgba(45,10,10,0.8); --bg-glass: rgba(220,20,60,0.2); --text-primary: #ffe6e6; --text-secondary: #d8aaaa; --text-muted: #a07070; --accent: #dc143c; --accent-hover: #ff1744; --border: rgba(220,20,60,0.3); }
        [data-theme="navy"] { --bg-primary: #0a0a1a; --bg-secondary: #151530; --bg-card: rgba(21,21,48,0.8); --bg-glass: rgba(0,0,128,0.2); --text-primary: #e6e6ff; --text-secondary: #a8a8d8; --text-muted: #7070a0; --accent: #4169e1; --accent-hover: #6495ed; --border: rgba(65,105,225,0.3); }
        [data-theme="emerald"] { --bg-primary: #001a0a; --bg-secondary: #003315; --bg-card: rgba(0,51,21,0.8); --bg-glass: rgba(0,201,87,0.2); --text-primary: #e6fff0; --text-secondary: #a8e0c8; --text-muted: #60a090; --accent: #00c957; --accent-hover: #00e060; --border: rgba(0,201,87,0.3); }
        [data-theme="cherry"] { --bg-primary: #1a050a; --bg-secondary: #300d15; --bg-card: rgba(48,13,21,0.8); --bg-glass: rgba(255,0,32,0.15); --text-primary: #fff0f3; --text-secondary: #e8b0b8; --text-muted: #b88088; --accent: #ff0040; --accent-hover: #ff2052; --border: rgba(255,0,64,0.2); }
        [data-theme="sand"] { --bg-primary: #f5f0e6; --bg-secondary: #ebe0cc; --bg-card: rgba(210,180,140,0.4); --bg-glass: rgba(194,154,107,0.2); --text-primary: #3d3428; --text-secondary: #5a4a38; --text-muted: #8a7a68; --accent: #c2a060; --accent-hover: #d4b070; --border: rgba(194,154,107,0.3); }
        [data-theme="carbon"] { --bg-primary: #1a1a1a; --bg-secondary: #2d2d2d; --bg-card: rgba(45,45,45,0.8); --bg-glass: rgba(100,100,100,0.2); --text-primary: #e0e0e0; --text-secondary: #b0b0b0; --text-muted: #808080; --accent: #808080; --accent-hover: #a0a0a0; --border: rgba(128,128,128,0.3); }
        [data-theme="nordic"] { --bg-primary: #2e3440; --bg-secondary: #3b4252; --bg-card: rgba(59,66,82,0.8); --bg-glass: rgba(129,161,193,0.15); --text-primary: #eceff4; --text-secondary: #d8dee9; --text-muted: #a8b0c0; --accent: #88c0d0; --accent-hover: #8fbcbb; --border: rgba(136,192,208,0.3); }
        [data-theme="nord"] { --bg-primary: #d8dee9; --bg-secondary: #e5e9f0; --bg-card: rgba(216,222,233,0.9); --bg-glass: rgba(46,52,64,0.1); --text-primary: #2e3440; --text-secondary: #3b4252; --text-muted: #4c566a; --accent: #5e81ac; --accent-hover: #81a1c1; --border: rgba(94,129,172,0.3); }
        [data-theme="dracula"] { --bg-primary: #282a36; --bg-secondary: #323444; --bg-card: rgba(50,50,68,0.8); --bg-glass: rgba(68,71,90,0.4); --text-primary: #f8f8f2; --text-secondary: #d8d8e8; --text-muted: #9090a0; --accent: #bd93f9; --accent-hover: #ff79c6; --border: rgba(189,147,249,0.3); }
        [data-theme="monokai"] { --bg-primary: #272822; --bg-secondary: #3e3d32; --bg-card: rgba(62,61,50,0.8); --bg-glass: rgba(117,113,94,0.3); --text-primary: #f8f8f2; --text-secondary: #cfcfc2; --text-muted: #a0a090; --accent: #f92672; --accent-hover: #fd971f; --border: rgba(249,38,114,0.3); }
        [data-theme="gruvbox-dark"] { --bg-primary: #282828; --bg-secondary: #3c3836; --bg-card: rgba(60,56,54,0.8); --bg-glass: rgba(80,73,69,0.3); --text-primary: #ebdbb2; --text-secondary: #d5c4a1; --text-muted: #a89984; --accent: #fb4934; --accent-hover: #fe8019; --border: rgba(251,73,52,0.3); }
        [data-theme="gruvbox-light"] { --bg-primary: #fbf1c7; --bg-secondary: #f2e6bc; --bg-card: rgba(242,230,188,0.9); --bg-glass: rgba(213,196,161,0.4); --text-primary: #282828; --text-secondary: #3c3836; --text-muted: #5c5c50; --accent: #cc241d; --accent-hover: #d65d0e; --border: rgba(204,36,29,0.3); }
        [data-theme="github-dark"] { --bg-primary: #0d1117; --bg-secondary: #161b22; --bg-card: rgba(22,27,34,0.8); --bg-glass: rgba(33,38,45,0.5); --text-primary: #c9d1d9; --text-secondary: #8b949e; --text-muted: #6e7681; --accent: #58a6ff; --accent-hover: #79c0ff; --border: rgba(88,166,255,0.3); }
        [data-theme="github-light"] { --bg-primary: #ffffff; --bg-secondary: #f6f8fa; --bg-card: rgba(246,248,250,0.9); --bg-glass: rgba(208,215,222,0.3); --text-primary: #24292f; --text-secondary: #57606a; --text-muted: #8c959f; --accent: #0969da; --accent-hover: #0550ae; --border: rgba(9,105,218,0.3); }
        [data-theme="one-dark"] { --bg-primary: #282c34; --bg-secondary: #3a3f4b; --bg-card: rgba(58,63,75,0.8); --bg-glass: rgba(97,103,118,0.25); --text-primary: #abb2bf; --text-secondary: #9da5b4; --text-muted: #7c8390; --accent: #61afef; --accent-hover: #98c379; --border: rgba(97,175,239,0.3); }
        [data-theme="one-light"] { --bg-primary: #fafafa; --bg-secondary: #eeeeee; --bg-card: rgba(238,238,238,0.9); --bg-glass: rgba(220,220,220,0.4); --text-primary: #383a42; --text-secondary: #4f525e; --text-muted: #7a7d85; --accent: #4078f2; --accent-hover: #5a7ef2; --border: rgba(64,120,242,0.3); }
        [data-theme="material-dark"] { --bg-primary: #121212; --bg-secondary: #1e1e1e; --bg-card: rgba(30,30,30,0.8); --bg-glass: rgba(38,38,38,0.5); --text-primary: #ffffff; --text-secondary: #b0b0b0; --text-muted: #707070; --accent: #82b1ff; --accent-hover: #b3e5fc; --border: rgba(130,177,255,0.3); }
        [data-theme="material-light"] { --bg-primary: #fafafa; --bg-secondary: #ffffff; --bg-card: rgba(255,255,255,0.95); --bg-glass: rgba(245,245,245,0.7); --text-primary: #212121; --text-secondary: #757575; --text-muted: #9e9e9e; --accent: #2196f3; --accent-hover: #64b5f6; --border: rgba(33,150,243,0.3); }
        [data-theme="solarized-dark"] { --bg-primary: #002b36; --bg-secondary: #073642; --bg-card: rgba(7,54,66,0.8); --bg-glass: rgba(0,43,54,0.5); --text-primary: #fdf6e3; --text-secondary: #eee8d5; --text-muted: #93a1a1; --accent: #268bd2; --accent-hover: #2aa198; --border: rgba(38,139,210,0.3); }
        [data-theme="solarized-light"] { --bg-primary: #fdf6e3; --bg-secondary: #eee8d5; --bg-card: rgba(238,232,213,0.9); --bg-glass: rgba(253,246,227,0.6); --text-primary: #002b36; --text-secondary: #073642; --text-muted: #586e75; --accent: #268bd2; --accent-hover: #2aa198; --border: rgba(38,139,210,0.3); }
        [data-theme="tokyo-night"] { --bg-primary: #1a1b26; --bg-secondary: #24283b; --bg-card: rgba(36,40,59,0.8); --bg-glass: rgba(63,65,89,0.3); --text-primary: #c0caf5; --text-secondary: #a9b1d6; --text-muted: #565f89; --accent: #7aa2f7; --accent-hover: #9ece6a; --border: rgba(122,162,247,0.3); }
        [data-theme="tokyo-night-storm"] { --bg-primary: #24283b; --bg-secondary: #2f3549; --bg-card: rgba(47,53,73,0.8); --bg-glass: rgba(119,124,145,0.2); --text-primary: #c0caf5; --text-secondary: #a9b1d6; --text-muted: #565f89; --accent: #7aa2f7; --accent-hover: #9ece6a; --border: rgba(122,162,247,0.3); }
        [data-theme="catppuccin-mocha"] { --bg-primary: #1e1e2e; --bg-secondary: #313244; --bg-card: rgba(49,50,68,0.8); --bg-glass: rgba(88,91,112,0.2); --text-primary: #cdd6f4; --text-secondary: #bac2de; --text-muted: #6c7086; --accent: #89b4fa; --accent-hover: #f38ba8; --border: rgba(137,180,250,0.3); }
        [data-theme="catppuccin-latte"] { --bg-primary: #eff1f5; --bg-secondary: #e6e9ef; --bg-card: rgba(230,233,239,0.9); --bg-glass: rgba(205,208,217,0.4); --text-primary: #4c4f69; --text-secondary: #5c5f77; --text-muted: #9ca0b0; --accent: #1e66f5; --accent-hover: #d20f39; --border: rgba(30,102,245,0.3); }
        [data-theme="night-owl"] { --bg-primary: #011627; --bg-secondary: #0d2944; --bg-card: rgba(13,41,68,0.8); --bg-glass: rgba(148,204,214,0.15); --text-primary: #d6deeb; --text-secondary: #b4d0e8; --text-muted: #637777; --accent: #82aaff; --accent-hover: #add7ff; --border: rgba(130,170,255,0.3); }
        [data-theme="night-owl-light"] { --bg-primary: #faf8f5; --bg-secondary: #f2f0eb; --bg-card: rgba(242,240,235,0.9); --bg-glass: rgba(194,193,186,0.4); --text-primary: #011627; --text-secondary: #0d2944; --text-muted: #637777; --accent: #2e6396; --accent-hover: #082968; --border: rgba(46,99,150,0.3); }
        [data-theme="poimandres"] { --bg-primary: #1b1e28; --bg-secondary: #24283b; --bg-card: rgba(36,40,59,0.8); --bg-glass: rgba(57,65,89,0.3); --text-primary: #d3e1e8; --text-secondary: #a6accd; --text-muted: #717897; --accent: #7dcfff; --accent-hover: #00f1a9; --border: rgba(125,207,255,0.3); }
        [data-theme="palenight"] { --bg-primary: #292d3e; --bg-secondary: #343b52; --bg-card: rgba(52,59,82,0.8); --bg-glass: rgba(69,76,101,0.3); --text-primary: #d0d5e8; --text-secondary: #959dcb; --text-muted: #676e95; --accent: #c792ea; --accent-hover: #f78c6c; --border: rgba(199,146,234,0.3); }
        [data-theme="shades-of-purple"] { --bg-primary: #1f1a3d; --bg-secondary: #2d2766; --bg-card: rgba(45,39,102,0.8); --bg-glass: rgba(97,78,249,0.2); --text-primary: #f8f8f2; --text-secondary: #c5c9f0; --text-muted: #8a8aad; --accent: #fb9f00; --accent-hover: #ff79c6; --border: rgba(251,159,0,0.3); }
        [data-theme="vscode-dark"] { --bg-primary: #1e1e1e; --bg-secondary: #252526; --bg-card: rgba(37,37,38,0.8); --bg-glass: rgba(45,45,46,0.5); --text-primary: #d4d4d4; --text-secondary: #9d9d9d; --text-muted: #6e6e6e; --accent: #007acc; --accent-hover: #3794ff; --border: rgba(0,122,204,0.3); }
        [data-theme="aurora-x"] { --bg-primary: #141426; --bg-secondary: #1e1e3a; --bg-card: rgba(30,30,58,0.8); --bg-glass: rgba(100,80,200,0.15); --text-primary: #e8e8f0; --text-secondary: #b0b0d0; --text-muted: #707090; --accent: #8b5cf6; --accent-hover: #a78bfa; --border: rgba(139,92,246,0.3); }
        [data-theme="neon"] { --bg-primary: #0a0a0a; --bg-secondary: #151515; --bg-card: rgba(21,21,21,0.8); --bg-glass: rgba(0,255,128,0.1); --text-primary: #00ff00; --text-secondary: #00cc00; --text-muted: #009900; --accent: #ff00ff; --accent-hover: #00ffff; --border: rgba(0,255,0,0.3); text-shadow: 0 0 5px currentColor; }
        
        /* 20 More Unique Themes */
        [data-theme="cyberpunk"] { --bg-primary: #0d0221; --bg-secondary: #1a0533; --bg-card: rgba(26,5,51,0.9); --bg-glass: rgba(255,0,255,0.15); --text-primary: #ff00ff; --text-secondary: #ff66ff; --text-muted: #cc00cc; --accent: #00ffff; --accent-hover: #00ff9f; --border: rgba(255,0,255,0.4); text-shadow: 0 0 10px rgba(255,0,255,0.5); }
        [data-theme="matrix"] { --bg-primary: #000000; --bg-secondary: #001100; --bg-card: rgba(0,17,0,0.95); --bg-glass: rgba(0,255,0,0.1); --text-primary: #00ff00; --text-secondary: #00cc00; --text-muted: #009900; --accent: #00ff00; --accent-hover: #33ff33; --border: rgba(0,255,0,0.2); font-family: 'Courier New', monospace; }
        [data-theme="hacker-green"] { --bg-primary: #0a0a0a; --bg-secondary: #0f1a0f; --bg-card: rgba(15,26,15,0.9); --bg-glass: rgba(0,255,0,0.08); --text-primary: #00ff41; --text-secondary: #00cc33; --text-muted: #009926; --accent: #00ff41; --accent-hover: #33ff66; --border: rgba(0,255,65,0.25); }
        [data-theme="amber"] { --bg-primary: #1a1400; --bg-secondary: #2d2200; --bg-card: rgba(45,34,0,0.9); --bg-glass: rgba(255,191,0,0.15); --text-primary: #ffd699; --text-secondary: #ffcc80; --text-muted: #cc9966; --accent: #ffb300; --accent-hover: #ffc107; --border: rgba(255,179,0,0.3); }
        [data-theme="copper"] { --bg-primary: #1a0f08; --bg-secondary: #2d1a0f; --bg-card: rgba(45,26,15,0.9); --bg-glass: rgba(184,115,51,0.15); --text-primary: #e8c8a8; --text-secondary: #d4a574; --text-muted: #a67c52; --accent: #b87333; --accent-hover: #cd7f32; --border: rgba(184,115,51,0.3); }
        [data-theme="copper-light"] { --bg-primary: #faf5f0; --bg-secondary: #f0e8e0; --bg-card: rgba(240,232,224,0.95); --bg-glass: rgba(184,115,51,0.1); --text-primary: #4a3528; --text-secondary: #6b4f3a; --text-muted: #8a7060; --accent: #b87333; --accent-hover: #cd7f32; --border: rgba(184,115,51,0.25); }
        [data-theme="vaporwave"] { --bg-primary: #1a0a2e; --bg-secondary: #2d1547; --bg-card: rgba(45,21,71,0.9); --bg-glass: rgba(255,105,180,0.15); --text-primary: #ff6ec7; --text-secondary: #c8a8e8; --text-muted: #9966cc; --accent: #00fff9; --accent-hover: #ff6ec7; --border: rgba(255,110,199,0.3); text-shadow: 0 0 8px rgba(0,255,249,0.5); }
        [data-theme="synthwave"] { --bg-primary: #1a0a2e; --bg-secondary: #2d1547; --bg-card: rgba(45,21,71,0.9); --bg-glass: rgba(255,0,128,0.15); --text-primary: #ff66ff; --text-secondary: #ff99ff; --text-muted: #cc66cc; --accent: #ff00ff; --accent-hover: #ff6600; --border: rgba(255,0,255,0.3); background-image: linear-gradient(180deg, transparent 0%, rgba(255,0,128,0.05) 100%); }
        [data-theme="terminal"] { --bg-primary: #0c0c0c; --bg-secondary: #1a1a1a; --bg-card: rgba(26,26,26,0.95); --bg-glass: rgba(0,255,0,0.05); --text-primary: #00ff00; --text-secondary: #00cc00; --text-muted: #009900; --accent: #00ff00; --accent-hover: #33ff33; --border: rgba(0,255,0,0.2); font-family: 'Courier New', monospace; }
        [data-theme="monokai-pro"] { --bg-primary: #2D2A2E; --bg-secondary: #403E41; --bg-card: rgba(64,62,65,0.9); --bg-glass: rgba(137,224,81,0.1); --text-primary: #FCFCFA; --text-secondary: #C4C4C7; --text-muted: #8A8A8E; --accent: #A6E22E; --accent-hover: #F71B8F; --border: rgba(166,226,46,0.3); }
        [data-theme="horizon"] { --bg-primary: #1a1418; --bg-secondary: #2d1f24; --bg-card: rgba(45,31,36,0.9); --bg-glass: rgba(255,84,86,0.15); --text-primary: #fceada; --text-secondary: #e8a098; --text-muted: #c47870; --accent: #ff845e; --accent-hover: #ff6b6b; --border: rgba(255,132,94,0.3); }
        [data-theme="horizon-dark"] { --bg-primary: #1a1418; --bg-secondary: #2d1f24; --bg-card: rgba(45,31,36,0.9); --bg-glass: rgba(255,84,86,0.2); --text-primary: #fceada; --text-secondary: #e8a098; --text-muted: #c47870; --accent: #ff6b6b; --accent-hover: #ff845e; --border: rgba(255,107,107,0.35); }
        [data-theme="everforest"] { --bg-primary: #2d3830; --bg-secondary: #3d4a3f; --bg-card: rgba(61,74,63,0.9); --bg-glass: rgba(147,173,144,0.15); --text-primary: #d3c7a9; --text-secondary: #a7b094; --text-muted: #7a846e; --accent: #a7c10f; --accent-hover: #8ca604; --border: rgba(167,193,15,0.3); }
        [data-theme="rose-pine"] { --bg-primary: #191724; --bg-secondary: #26233a; --bg-card: rgba(38,35,58,0.9); --bg-glass: rgba(235,219,208,0.08); --text-primary: #e0def4; --text-secondary: #908caa; --text-muted: #6e6a86; --accent: #c4a7e7; --accent-hover: #ebbcba; --border: rgba(196,167,231,0.25); }
        [data-theme="rose-pine-dawn"] { --bg-primary: #faf4ed; --bg-secondary: #fffaf3; --bg-card: rgba(255,250,243,0.95); --bg-glass: rgba(175,153,174,0.15); --text-primary: #5f5a6e; --text-secondary: #797593; --text-muted: #9691a8; --accent: #b4637a; --accent-hover: #d7827e; --border: rgba(180,99,122,0.25); }
        [data-theme="kanagawa"] { --bg-primary: #1f1b24; --bg-secondary: #2a2730; --bg-card: rgba(42,39,48,0.9); --bg-glass: rgba(118,212,212,0.15); --text-primary: #dcd7be; --text-secondary: #a6a69b; --text-muted: #727169; --accent: #7e9cd8; --accent-hover: #98bb6d; --border: rgba(126,156,216,0.3); }
        [data-theme="kanagawa-light"] { --bg-primary: #f2ede8; --bg-secondary: #fff8f3; --bg-card: rgba(255,248,243,0.95); --bg-glass: rgba(118,212,212,0.1); --text-primary: #3d3b38; --text-secondary: #5c5854; --text-muted: #7a7872; --accent: #769468; --accent-hover: #d06c2c; --border: rgba(118,212,212,0.25); }
        [data-theme="catppuccin-frappe"] { --bg-primary: #232193; --bg-secondary: #292c3c; --bg-card: rgba(41,44,60,0.9); --bg-glass: rgba(205,214,244,0.12); --text-primary: #c6d0f4; --text-secondary: #a5adcb; --text-muted: #838ba7; --accent: #8caa; --accent-hover: #ca9ee6; --border: rgba(140,170,238,0.3); }
        [data-theme="gruvbox-material"] { --bg-primary: #282828; --bg-secondary: #32302f; --bg-card: rgba(50,48,47,0.9); --bg-glass: rgba(213,196,161,0.12); --text-primary: #dfbf8e; --text-secondary: #a9b19b; --text-muted: #8a8a78; --accent: #83c07c; --accent-hover: #e6b466; --border: rgba(131,192,124,0.3); }

        /* Responsive */
        @media (max-width: 768px) {
            .header-content {
                flex-wrap: wrap;
            }
            
            .search-container {
                order: 3;
                width: 100%;
                max-width: none;
                margin-top: 15px;
            }
            
            .nav {
                gap: 10px;
            }
            
            .nav-link span {
                display: none;
            }
        }
    </style>
    
    {% block extra_head %}{% endblock %}
</head>
<body>
    <!-- Header -->
    <header class="header">
        <div class="header-content">
            <a href="/" class="logo">
                <svg class="icon logo-icon" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                </svg>
                <span>{{ config.APP_NAME }}</span>
            </a>
            
            <div class="search-container">
                <form action="/search" method="GET" class="search-form">
                    <input type="text" name="q" class="search-input" placeholder="Search the web privately..." autocomplete="off">
                    <button type="submit" class="search-btn">
                        <svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                    </button>
                </form>
            </div>
            
            <nav class="nav">
                <a href="/settings" class="nav-link">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.14 12.94c.04-.31.06-.63.06-.94 0-.31-.02-.63-.06-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.04.31-.06.63-.06.94s.02.63.06.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>
                    <span>Settings</span>
                </a>
                
                <button class="theme-toggle" onclick="toggleTheme()" title="Toggle theme">
                    <svg class="sun-icon" viewBox="0 0 24 24"><path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41l-1.06-1.06zm1.06-10.96c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 18.36c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/></svg>
                </button>
            </nav>
        </div>
    </header>

    <!-- Main content -->
    <main>
        {% block content %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="footer-links">
            <a href="/about">About</a>
            <a href="/privacy">Privacy</a>
            <a href="/privacy/insane">Insane Privacy</a>
            <a href="/terms">Terms</a>
            <a href="https://github.com/atomic-search/atomic-search" target="_blank">GitHub</a>
        </div>
        <p>{{ config.APP_NAME }} v{{ config.VERSION }} - Privacy-first search</p>
        <p>No tracking. No ads. No cookies.</p>
    </footer>

    <script>
        // Theme toggle
        function toggleTheme() {
            const html = document.documentElement;
            const currentTheme = html.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', newTheme);
            document.cookie = `theme=${newTheme};path=/;max-age=31536000`;
            
            // Update icon
            const sunIcon = document.querySelector('.sun-icon');
            if (newTheme === 'light') {
                sunIcon.innerHTML = '<path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36-.98 1.37-2.58 2.26-4.4 2.26-2.98 0-5.4-2.42-5.4-5.4 0-1.81.89-3.42 2.26-4.4-.44-.06-.9-.1-1.36-.1z"/>';
            } else {
                sunIcon.innerHTML = '<path d="M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zM2 13h2c.55 0 1-.45 1-1s-.45-1-1-1H2c-.55 0-1 .45-1 1s.45 1 1 1zm18 0h2c.55 0 1-.45 1-1s-.45-1-1-1h-2c-.55 0-1 .45-1 1s.45 1 1 1zM11 2v2c0 .55.45 1 1 1s1-.45 1-1V2c0-.55-.45-1-1-1s-1 .45-1 1zm0 18v2c0 .55.45 1 1 1s1-.45 1-1v-2c0-.55-.45-1-1-1s-1 .45-1 1zM5.99 4.58c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0s.39-1.03 0-1.41L5.99 4.58zm12.37 12.37c-.39-.39-1.03-.39-1.41 0-.39.39-.39 1.03 0 1.41l1.06 1.06c.39.39 1.03.39 1.41 0 .39-.39.39-1.03 0-1.41l-1.06-1.06zm1.06-10.96c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06zM7.05 18.36c.39-.39.39-1.03 0-1.41-.39-.39-1.03-.39-1.41 0l-1.06 1.06c-.39.39-.39 1.03 0 1.41s1.03.39 1.41 0l1.06-1.06z"/>';
            }
        }

        // Load saved theme
        document.addEventListener('DOMContentLoaded', () => {
            const savedTheme = document.cookie.match(/theme=(\w+)/)?.[1] || 'dark';
            document.documentElement.setAttribute('data-theme', savedTheme);
        });
    </script>
</body>
</html>
